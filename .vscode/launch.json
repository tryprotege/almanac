{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Benchmarking (Default)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@ebee/benchmarking", "dev"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"],
      "envFile": "${workspaceFolder}/packages/benchmarking/.env"
    },
    {
      "name": "Debug Benchmarking (Small - 30 days)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@ebee/benchmarking", "generate:small"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"],
      "envFile": "${workspaceFolder}/packages/benchmarking/.env"
    },
    {
      "name": "Debug Benchmarking (Medium - 180 days)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@ebee/benchmarking", "generate:medium"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"],
      "envFile": "${workspaceFolder}/packages/benchmarking/.env"
    },
    {
      "name": "Debug Benchmarking (Large - 365 days)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@ebee/benchmarking", "generate:large"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"],
      "envFile": "${workspaceFolder}/packages/benchmarking/.env"
    },
    {
      "name": "Debug Benchmarking (Direct tsx)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "--loader",
        "tsx",
        "${workspaceFolder}/packages/benchmarking/src/mock-data-generator/index.ts"
      ],
      "cwd": "${workspaceFolder}/packages/benchmarking",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"],
      "envFile": "${workspaceFolder}/packages/benchmarking/.env",
      "resolveSourceMapLocations": [
        "${workspaceFolder}/**",
        "!**/node_modules/**"
      ]
    }
  ]
}
