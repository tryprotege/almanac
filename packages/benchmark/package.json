{
  "name": "@ebee-oss/benchmark",
  "version": "0.1.0",
  "description": "Benchmarking framework for eBee MCP server performance testing",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./types": "./dist/types/index.js",
    "./runners": "./dist/runners/index.js",
    "./evaluators": "./dist/evaluators/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "build": "tsc",
    "benchmark": "tsx src/index.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@ebee-oss/server": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.24.3",
    "dotenv": "^17.2.3",
    "openai": "^6.9.1",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
