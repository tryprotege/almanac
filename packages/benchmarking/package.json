{
  "name": "@ebee/benchmarking",
  "version": "0.1.0",
  "description": "Benchmarking tools for multi-source data integration",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "generate": "tsx src/mock-data-generator/index.ts",
    "build": "tsc",
    "generate:small": "TIMELINE_DAYS=7 tsx src/mock-data-generator/index.ts",
    "generate:medium": "TIMELINE_DAYS=180 tsx src/mock-data-generator/index.ts",
    "generate:large": "TIMELINE_DAYS=365 tsx src/mock-data-generator/index.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@ebee-oss/shared-util": "workspace:*",
    "@slack/web-api": "^7.11.0",
    "dotenv": "^16.4.7",
    "openai": "^4.73.0",
    "p-limit": "^7.2.0",
    "p-retry": "^7.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  }
}