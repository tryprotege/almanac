{
  "name": "@ebee-oss/mock-mcp-server",
  "version": "1.0.0",
  "description": "Mock MCP server with GitHub, Fathom, Notion, and Slack tools",
  "main": "dist/server.js",
  "type": "module",
  "bin": {
    "mock-mcp-server": "./dist/server.js"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "mock",
    "github",
    "fathom",
    "notion",
    "slack"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.24.3 ",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "zod": "4.1.13"
  },
  "devDependencies": {
    "@types/node": "^25.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}