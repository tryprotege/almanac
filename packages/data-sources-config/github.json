{
  "id": "github",
  "displayName": "GitHub",
  "description": "Code repository and collaboration platform",
  "icon": "github",
  "category": "development",
  "connection": {
    "type": "streamable-http",
    "url": "https://api.githubcopilot.com/mcp"
  },
  "variables": [
    {
      "key": "GITHUB_TOKEN",
      "label": "GitHub Personal Access Token",
      "type": "password",
      "required": true,
      "helpText": "Your GitHub personal access token with appropriate scopes (repo, read:org, etc.)"
    }
  ],
  "indexingConfig": {
    "version": "1.0",
    "source": "github",
    "displayName": "GitHub",
    "startingPoints": [
      {
        "name": "query",
        "type": "manual",
        "description": "GitHub search query to find repositories. Use GitHub search syntax: 'user:username' for user repos, 'org:orgname' for organization repos, 'topic:topicname' for topics, or combine criteria. Examples: 'user:facebook', 'org:microsoft', 'topic:machine-learning', 'user:vercel topic:nextjs', 'org:kubernetes language:go'",
        "userProvided": true,
        "required": true
      }
    ],
    "rateLimit": {
      "maxRequests": 3600,
      "windowSeconds": 3600,
      "strategy": "token_bucket",
      "allowBurst": true,
      "burstMultiplier": 1.5
    },
    "syncOrder": [
      "search_repositories",
      "list_issues",
      "list_pull_requests",
      "list_releases",
      "list_discussions"
    ],
    "fetchers": {
      "search_repositories": {
        "tool": "search_repositories",
        "seedFrom": {
          "startingPoint": "query",
          "paramMapping": {
            "query": "$"
          }
        },
        "params": {
          "minimal_output": false
        },
        "resultPath": "$.content[0].text",
        "arrayPath": "$.items[*]",
        "pagination": {
          "type": "offset",
          "pageParam": "page",
          "limitParam": "perPage"
        },
        "detection": {
          "type": "always"
        }
      },
      "list_issues": {
        "tool": "list_issues",
        "forEach": {
          "source": "search_repositories",
          "path": "$[*]",
          "paramMapping": {
            "owner": "$.owner.login",
            "repo": "$.name"
          },
          "concurrency": 3,
          "continueOnError": true,
          "retries": 2
        },
        "resultPath": "$.content[0].text",
        "arrayPath": "$.issues[*]",
        "pagination": {
          "type": "cursor",
          "cursorParam": "after",
          "cursorPath": "$.pageInfo.endCursor",
          "hasNextPath": "$.pageInfo.hasNextPage"
        },
        "detection": {
          "type": "always"
        },
        "cutoffDate": {
          "strategy": "both",
          "apiParam": "since",
          "apiFormat": "iso8601",
          "dateFieldPath": "$.created_at"
        }
      },
      "list_pull_requests": {
        "tool": "list_pull_requests",
        "forEach": {
          "source": "search_repositories",
          "path": "$[*]",
          "paramMapping": {
            "owner": "$.owner.login",
            "repo": "$.name",
            "state": "all"
          },
          "concurrency": 3,
          "continueOnError": true,
          "retries": 2
        },
        "resultPath": "$.content[0].text",
        "pagination": {
          "type": "offset",
          "pageParam": "page",
          "limitParam": "perPage"
        },
        "detection": {
          "type": "always"
        },
        "cutoffDate": {
          "strategy": "post_fetch",
          "dateFieldPath": "$.created_at"
        }
      },
      "list_releases": {
        "tool": "list_releases",
        "forEach": {
          "source": "search_repositories",
          "path": "$[*]",
          "paramMapping": {
            "owner": "$.owner.login",
            "repo": "$.name"
          },
          "concurrency": 3,
          "continueOnError": true,
          "retries": 2
        },
        "resultPath": "$.content[0].text",
        "pagination": {
          "type": "offset",
          "pageParam": "page",
          "limitParam": "perPage"
        },
        "detection": {
          "type": "always"
        },
        "cutoffDate": {
          "strategy": "post_fetch",
          "dateFieldPath": "$.published_at"
        }
      },
      "list_discussions": {
        "tool": "list_discussions",
        "forEach": {
          "source": "search_repositories",
          "path": "$[*]",
          "paramMapping": {
            "owner": "$.owner.login",
            "repo": "$.name"
          },
          "concurrency": 3,
          "continueOnError": true,
          "retries": 2
        },
        "resultPath": "$.content[0].text",
        "arrayPath": "$.discussions[*]",
        "pagination": {
          "type": "cursor",
          "cursorParam": "after",
          "cursorPath": "$.pageInfo.endCursor",
          "hasNextPath": "$.pageInfo.hasNextPage"
        },
        "detection": {
          "type": "always"
        },
        "cutoffDate": {
          "strategy": "post_fetch",
          "dateFieldPath": "$.created_at"
        }
      }
    },
    "recordTypes": {
      "repository": {
        "name": "repository",
        "fetcher": "search_repositories",
        "fields": {
          "title": {
            "type": "path",
            "path": "$.full_name"
          },
          "content": {
            "type": "template",
            "template": "${record.full_name}\n${record.description || ''}\nLanguage: ${record.language || 'N/A'}\nTopics: ${record.topics?.join(', ') || ''}"
          },
          "people": {
            "type": "path",
            "path": "$.owner.login"
          },
          "sourceCreatedAt": {
            "type": "path",
            "path": "$.created_at"
          },
          "sourceUpdatedAt": {
            "type": "path",
            "path": "$.updated_at"
          },
          "tags": {
            "type": "paths",
            "paths": ["$.topics[*]", "$.language"]
          }
        },
        "entities": [
          {
            "name": "owner",
            "type": "User",
            "idPath": "$.owner.login",
            "titlePath": "$.owner.login",
            "condition": "record.owner && record.owner.login"
          }
        ],
        "relationships": [
          {
            "name": "owned_by",
            "type": "OWNED_BY",
            "targetType": "User",
            "targetIdPath": "$.owner.login",
            "condition": "record.owner && record.owner.login"
          }
        ]
      },
      "issue": {
        "name": "issue",
        "fetcher": "list_issues",
        "fields": {
          "title": {
            "type": "template",
            "template": "#${record.number}: ${record.title}"
          },
          "content": {
            "type": "path",
            "path": "$.body"
          },
          "people": {
            "type": "paths",
            "paths": ["$.user.login", "$.assignees[*].login"]
          },
          "sourceCreatedAt": {
            "type": "path",
            "path": "$.created_at"
          },
          "sourceUpdatedAt": {
            "type": "path",
            "path": "$.updated_at"
          },
          "tags": {
            "type": "paths",
            "paths": ["$.state", "$.labels[*].name"]
          }
        },
        "entities": [
          {
            "name": "creator",
            "type": "User",
            "idPath": "$.user.login",
            "titlePath": "$.user.login",
            "condition": "record.user && record.user.login"
          },
          {
            "name": "assignee",
            "type": "User",
            "idPath": "$.assignees[*].login",
            "titlePath": "$.assignees[*].login",
            "condition": "record.assignees && record.assignees.length > 0"
          }
        ],
        "relationships": [
          {
            "name": "created_by",
            "type": "CREATED_BY",
            "targetType": "User",
            "targetIdPath": "$.user.login",
            "condition": "record.user && record.user.login"
          },
          {
            "name": "assigned_to",
            "type": "ASSIGNED_TO",
            "targetType": "User",
            "targetIdPath": "$.assignees[*].login",
            "condition": "record.assignees && record.assignees.length > 0"
          }
        ]
      },
      "pull_request": {
        "name": "pull_request",
        "fetcher": "list_pull_requests",
        "fields": {
          "title": {
            "type": "template",
            "template": "PR #${record.number}: ${record.title}"
          },
          "content": {
            "type": "path",
            "path": "$.body"
          },
          "people": {
            "type": "paths",
            "paths": [
              "$.user.login",
              "$.assignees[*].login",
              "$.requested_reviewers[*].login",
              "$.merged_by.login"
            ]
          },
          "sourceCreatedAt": {
            "type": "path",
            "path": "$.created_at"
          },
          "sourceUpdatedAt": {
            "type": "path",
            "path": "$.updated_at"
          },
          "tags": {
            "type": "paths",
            "paths": ["$.state", "$.labels[*].name"]
          }
        },
        "entities": [
          {
            "name": "creator",
            "type": "User",
            "idPath": "$.user.login",
            "titlePath": "$.user.login",
            "condition": "record.user && record.user.login"
          },
          {
            "name": "assignee",
            "type": "User",
            "idPath": "$.assignees[*].login",
            "titlePath": "$.assignees[*].login",
            "condition": "record.assignees && record.assignees.length > 0"
          },
          {
            "name": "reviewer",
            "type": "User",
            "idPath": "$.requested_reviewers[*].login",
            "titlePath": "$.requested_reviewers[*].login",
            "condition": "record.requested_reviewers && record.requested_reviewers.length > 0"
          },
          {
            "name": "merger",
            "type": "User",
            "idPath": "$.merged_by.login",
            "titlePath": "$.merged_by.login",
            "condition": "record.merged_by && record.merged_by.login"
          }
        ],
        "relationships": [
          {
            "name": "created_by",
            "type": "CREATED_BY",
            "targetType": "User",
            "targetIdPath": "$.user.login",
            "condition": "record.user && record.user.login"
          },
          {
            "name": "assigned_to",
            "type": "ASSIGNED_TO",
            "targetType": "User",
            "targetIdPath": "$.assignees[*].login",
            "condition": "record.assignees && record.assignees.length > 0"
          },
          {
            "name": "reviewed_by",
            "type": "REVIEWED_BY",
            "targetType": "User",
            "targetIdPath": "$.requested_reviewers[*].login",
            "condition": "record.requested_reviewers && record.requested_reviewers.length > 0"
          },
          {
            "name": "merged_by",
            "type": "MERGED_BY",
            "targetType": "User",
            "targetIdPath": "$.merged_by.login",
            "condition": "record.merged_by && record.merged_by.login"
          }
        ]
      },
      "release": {
        "name": "release",
        "fetcher": "list_releases",
        "fields": {
          "title": {
            "type": "paths",
            "paths": ["$.name", "$.tag_name"]
          },
          "content": {
            "type": "path",
            "path": "$.body"
          },
          "people": {
            "type": "path",
            "path": "$.author.login"
          },
          "sourceCreatedAt": {
            "type": "path",
            "path": "$.published_at"
          },
          "tags": {
            "type": "paths",
            "paths": ["$.tag_name"]
          }
        },
        "entities": [
          {
            "name": "author",
            "type": "User",
            "idPath": "$.author.login",
            "titlePath": "$.author.login",
            "condition": "record.author && record.author.login"
          }
        ],
        "relationships": [
          {
            "name": "created_by",
            "type": "CREATED_BY",
            "targetType": "User",
            "targetIdPath": "$.author.login",
            "condition": "record.author && record.author.login"
          }
        ]
      },
      "discussion": {
        "name": "discussion",
        "fetcher": "list_discussions",
        "fields": {
          "title": {
            "type": "path",
            "path": "$.title"
          },
          "content": {
            "type": "path",
            "path": "$.body"
          },
          "people": {
            "type": "paths",
            "paths": ["$.user.login", "$.answer_chosen_by.login"]
          },
          "sourceCreatedAt": {
            "type": "path",
            "path": "$.created_at"
          },
          "sourceUpdatedAt": {
            "type": "path",
            "path": "$.updated_at"
          },
          "tags": {
            "type": "paths",
            "paths": ["$.state", "$.category.name"]
          }
        },
        "entities": [
          {
            "name": "author",
            "type": "User",
            "idPath": "$.user.login",
            "titlePath": "$.user.login",
            "condition": "record.user && record.user.login"
          },
          {
            "name": "answer_chooser",
            "type": "User",
            "idPath": "$.answer_chosen_by.login",
            "titlePath": "$.answer_chosen_by.login",
            "condition": "record.answer_chosen_by && record.answer_chosen_by.login"
          }
        ],
        "relationships": [
          {
            "name": "started_by",
            "type": "STARTED_BY",
            "targetType": "User",
            "targetIdPath": "$.user.login",
            "condition": "record.user && record.user.login"
          },
          {
            "name": "answered_by",
            "type": "ANSWERED_BY",
            "targetType": "User",
            "targetIdPath": "$.answer_chosen_by.login",
            "condition": "record.answer_chosen_by && record.answer_chosen_by.login"
          }
        ]
      }
    },
    "toolClassifications": {
      "get_me": {
        "toolName": "get_me",
        "category": "read"
      },
      "search_repositories": {
        "toolName": "search_repositories",
        "category": "read"
      },
      "list_issues": {
        "toolName": "list_issues",
        "category": "read"
      },
      "list_pull_requests": {
        "toolName": "list_pull_requests",
        "category": "read"
      },
      "list_pull_request_reviews": {
        "toolName": "list_pull_request_reviews",
        "category": "read"
      },
      "list_issue_comments": {
        "toolName": "list_issue_comments",
        "category": "read"
      },
      "list_pull_request_comments": {
        "toolName": "list_pull_request_comments",
        "category": "read"
      },
      "list_releases": {
        "toolName": "list_releases",
        "category": "read"
      },
      "list_code_scanning_alerts": {
        "toolName": "list_code_scanning_alerts",
        "category": "read"
      },
      "list_dependabot_alerts": {
        "toolName": "list_dependabot_alerts",
        "category": "read"
      },
      "list_secret_scanning_alerts": {
        "toolName": "list_secret_scanning_alerts",
        "category": "read"
      },
      "list_discussions": {
        "toolName": "list_discussions",
        "category": "read"
      }
    }
  }
}
