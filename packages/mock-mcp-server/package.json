{
  "name": "@ebee-oss/mock-mcp-server",
  "version": "1.0.0",
  "description": "Generic MCP Server for mock data - supports Slack, Fathom, Notion, and GitHub mock data sources",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mock-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "tsx src/index.ts",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "mock",
    "slack",
    "fathom",
    "notion",
    "github",
    "testing",
    "benchmark"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@slack/web-api": "^7.11.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
