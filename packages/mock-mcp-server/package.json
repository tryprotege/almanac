{
  "name": "@ebee-oss/mock-mcp-server",
  "version": "1.0.0",
  "description": "Mock MCP server with GitHub, Fathom, Notion, and Slack tools",
  "main": "dist/server.js",
  "type": "module",
  "bin": {
    "mock-mcp-server": "./dist/server.js"
  },
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
