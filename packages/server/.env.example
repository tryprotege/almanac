# MongoDB Configuration
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USERNAME=admin
MONGO_PASSWORD=admin123
MONGO_DB_NAME=ebee

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Memgraph Configuration
MEMGRAPH_HOST=localhost
MEMGRAPH_PORT=7687
MEMGRAPH_USERNAME=
MEMGRAPH_PASSWORD=

# Qdrant Configuration
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# LLM Configuration (provider-agnostic)
# Supported providers: openai, openrouter, azure, anthropic
# Get your OpenRouter API key from: https://openrouter.ai/
LLM_PROVIDER=openrouter
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=

# Model Configuration - Separate for chat and embeddings
# Chat models: openai/gpt-oss-20b, openai/gpt-oss-120b
# Embedding models: qwen/qwen3-embedding-8b, qwen/qwen3-embedding-4b, qwen/qwen3-embedding-0.6b
LLM_CHAT_MODEL=openai/gpt-oss-20b
LLM_EMBEDDING_MODEL=qwen/qwen3-embedding-0.6b

# Reranker Configuration (optional - improves search relevance)
# Enable reranking for better search results (two-stage retrieval)
# Get your DeepInfra API key from: https://deepinfra.com/
RERANKER_ENABLED=false
RERANKER_API_KEY=your_deepinfra_api_key_here
RERANKER_BASE_URL=https://api.deepinfra.com/v1/inference
RERANKER_MODEL=Qwen/Qwen3-Reranker-8B

# Mock Data Feature (Development Only)
# Enable to use mock data instead of real databases
# Perfect for frontend development, demos, and testing UI without database setup
# Set to 'true' to use mock data, 'false' or leave empty to use real data
ENABLE_MOCK_DATA=false
