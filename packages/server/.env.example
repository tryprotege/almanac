# Logging Configuration
LOG_LEVEL=info

# MCP Debug Logs (set to true to see full MCP responses in logs, false to show only response length)
MCP_DEBUG_LOGS=false

# Disable Write Tools (set to true to filter out write operations from MCP servers, false to allow them)
# Default: false (write tools are allowed)
DISABLE_WRITE_TOOLS=false

# MongoDB Configuration
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USERNAME=admin
MONGO_PASSWORD=admin123
MONGO_DB_NAME=almanac

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Memgraph Configuration
MEMGRAPH_HOST=localhost
MEMGRAPH_PORT=7687
MEMGRAPH_USERNAME=
MEMGRAPH_PASSWORD=

# Qdrant Configuration
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# OAuth Configuration
OAUTH_REDIRECT_URI=http://localhost:3000/api/oauth/callback
OAUTH_CLIENT_URL=http://localhost:5173
IS_BENCHMARK=false

# LLM Configuration (provider-agnostic)
# Supported providers: openai, openrouter, azure, anthropic
# Get your OpenRouter API key from: https://openrouter.ai/
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=

# Model Configuration - Separate for chat and embeddings
# Chat models: openai/gpt-oss-20b, openai/gpt-oss-120b
# Embedding models: qwen/qwen3-embedding-8b, qwen/qwen3-embedding-4b, qwen/qwen3-embedding-0.6b
LLM_CHAT_MODEL=openai/gpt-oss-20b
LLM_EMBEDDING_MODEL=qwen/qwen3-embedding-4b
LLM_EXTRACTION_MODEL=openai/gpt-oss-120b

# Reranker Configuration (optional - improves search relevance)
# Enable reranking for better search results (two-stage retrieval)
# Get your Fireworks API key from: https://fireworks.ai/
RERANKER_ENABLED=false
RERANKER_BASE_URL=https://api.fireworks.ai/inference/v1/rerank
RERANKER_API_KEY=
RERANKER_MODEL=fireworks/qwen3-reranker-8b

# If on local DB
# Generate a key using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
# Indexing Concurrency Configuration
DB_INDEXING_CONCURRENCY=32
VECTOR_INDEXING_CONCURRENCY=32

# Graph Extraction Configuration
GRAPH_EXTRACTION_CONCURRENCY=32

# Toxic Document Filter (disabled by default)
# Filters out documents that look like lists, bibliographies, or indexes
# Detection heuristics: >50 entities, <5 relationships, <20 char avg entity names
# Set to true to enable filtering (may be too aggressive for some content)
ENABLE_TOXIC_DOCUMENT_FILTER=false

# Dynamic Entity Limit Configuration
# Ratio: 1 entity per X characters (optional, no limit if not set)
# Lower value = more entities per document (e.g., 40 = very generous)
# Higher value = fewer entities per document (e.g., 150 = more conservative)
# Leave empty or omit for no limit
# ENTITY_CHARS_PER_ENTITY=40

# Maximum entities per document cap (optional, no limit if not set)
# Dynamic limit = min(contentLength / ENTITY_CHARS_PER_ENTITY, MAX_ENTITIES_PER_DOCUMENT)
# If ENTITY_CHARS_PER_ENTITY is not set, this acts as a static limit
# Leave empty or omit for no limit
MAX_ENTITIES_PER_DOCUMENT=1000

# Sync Configuration
# SYNC_CUTOFF_DATE: Only sync data modified after this date (default: 60 days ago)
# SYNC_MAX_RECORDS: Maximum number of records to sync per data source (optional, no limit by default)
# SYNC_CRON_SCHEDULE: Cron expression for recurring automatic syncs (default: "0 0 * * *" - daily at midnight)
# Note: Times are interpreted in your local server timezone
# 
# Hybrid Scheduling Behavior:
# 1. On startup: Syncs data sources that missed their last scheduled sync (based on cron schedule)
# 2. While running: Syncs all enabled data sources according to SYNC_CRON_SCHEDULE
# 
# This approach ensures data freshness even if the server isn't running 24/7
#
# Defaults (if not specified):
# - SYNC_CUTOFF_DATE: 60 days ago from current date
# - SYNC_CRON_SCHEDULE: "0 0 * * *" (daily at midnight)
#
# Examples for SYNC_CRON_SCHEDULE:
#   "0 * * * *"     - Every hour
#   "0 0 * * *"     - Every day at midnight (DEFAULT)
#   "0 */6 * * *"   - Every 6 hours
#   "0 0 * * 0"     - Every Sunday at midnight
#
# Uncomment and modify to override defaults:
# SYNC_CUTOFF_DATE=2025-12-01T00:00:00.000Z
# SYNC_MAX_RECORDS=1000
# SYNC_CRON_SCHEDULE=0 0 * * *
